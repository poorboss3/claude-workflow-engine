{
  "ConnectionStrings": {
    "WorkflowDb": "Host=localhost;Port=5432;Database=workflow_db;Username=workflow_user;Password=workflow_pass",
    "Redis": "localhost:6379",
    "RabbitMq": "amqp://guest:guest@localhost:5672/"
  },
  "UseInMemoryDb": true,
  "Workflow": {
    "ExtensionPoint": {
      "TimeoutSeconds": 5,
      "RetryCount": 2
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*"
}
